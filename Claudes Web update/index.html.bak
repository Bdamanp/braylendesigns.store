                    <span class="portfolio-card-badge">Beauty</span>
                    <div class="portfolio-card-overlay">
                        <a href="portfolio.html" class="btn btn-primary" style="font-size:0.8125rem;padding:10px 20px;">View Demo</a>
                    </div>
                </div>
                <div class="portfolio-card-body">
                    <h3>Luxe Beauty Studio</h3>
                    <p>Elegant design with appointment scheduling and gallery.</p>
                </div>
            </div>
            <div class="portfolio-card reveal reveal-delay-3" >
                <div class="portfolio-card-img">
                    <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&q=80" alt="Restaurant website" loading="lazy">
                    <span class="portfolio-card-badge">Restaurant</span>
                    <div class="portfolio-card-overlay">
                        <a href="portfolio.html" class="btn btn-primary" style="font-size:0.8125rem;padding:10px 20px;">View Demo</a>
