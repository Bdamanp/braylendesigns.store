<!-- PROCESS -->
<section class="section">
    <div class="container">
        <div style="text-align:center;max-width:560px;margin:0 auto 64px;">
            <span class="section-label reveal">Our Process</span>
            <h2 class="section-title reveal">From idea to launch <span class="gradient-text">in days.</span></h2>
            <p class="section-subtitle reveal" style="margin:16px auto 0;">Four straightforward steps. No surprises, no scope creep, no endless revision cycles.</p>
        </div>
        <div class="process-grid">
            <div class="process-step reveal reveal-delay-1">
                <div class="process-number">01</div>
                <h4>Discovery</h4>
                <p>We learn your business, your customers, and your goals in a quick 30-minute call.</p>
                <span class="process-connector"></span>
            </div>
            <div class="process-step reveal reveal-delay-2">
                <div class="process-number">02</div>
                <h4>Design</h4>
                <p>You get a full design mockup within 48 hours. We refine it until it feels right.</p>
                <span class="process-connector"></span>
            </div>
            <div class="process-step reveal reveal-delay-3">
                <div class="process-number">03</div>
                <h4>Build</h4>
                <p>We code the site with clean, fast tech. Mobile-first, SEO-optimized, built to last.</p>
                <span class="process-connector"></span>
            </div>
            <div class="process-step reveal reveal-delay-4">
                <div class="process-number">04</div>
                <h4>Launch</h4>
                <p>Your site goes live. We handle hosting setup, domain config, and a final QA pass.</p>
            </div>
        </div>
    </div>
</section>

<div class="section-divider"></div>

<!-- PRICING -->
<section class="section" id="pricing">
    <div class="container">
        <div style="text-align:center;max-width:560px;margin:0 auto 64px;">
            <span class="section-label reveal">Pricing</span>
            <h2 class="section-title reveal">Transparent pricing, <span class="gradient-text">real results.</span></h2>
            <p class="section-subtitle reveal" style="margin:16px auto 0;">50% upfront, 50% on delivery. No hidden fees. No retainers unless you want one.</p>
        </div>
        <div class="grid-3">
            <div class="pricing-card reveal reveal-delay-1" >
                <span class="pricing-badge">New Build</span>
                <h3>Website Design</h3>
                <div class="price">$500 &ndash; $3,000</div>
                <p class="price-note">Based on scope and page count</p>
                <ul class="pricing-features">
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Custom design from scratch</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Mobile-responsive layout</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> SEO fundamentals included</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Contact form integration</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> 5-7 day delivery</li>
                </ul>
                <a href="#contact" class="btn btn-secondary">Get a Quote</a>
            </div>
            <div class="pricing-card featured reveal reveal-delay-2" >
                <span class="pricing-badge">Most Popular</span>
                <h3>Website Redesign</h3>
                <div class="price">$800 &ndash; $2,500</div>
                <p class="price-note">Upgrade your existing site</p>
                <ul class="pricing-features">
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Full visual overhaul</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Performance optimization</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Content migration</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Modern tech stack</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Analytics setup</li>
                </ul>
                <a href="#contact" class="btn btn-primary">Get a Quote</a>
            </div>
            <div class="pricing-card reveal reveal-delay-3" >
                <span class="pricing-badge">Ongoing</span>
                <h3>Monthly Maintenance</h3>
                <div class="price">$50 &ndash; $150<span style="font-size:1rem;font-weight:500;color:var(--muted);">/mo</span></div>
                <p class="price-note">Keep your site fast and fresh</p>
                <ul class="pricing-features">
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Monthly content updates</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Security monitoring</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Performance reports</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Priority support</li>
                    <li><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Hosting management</li>
                </ul>
                <a href="#contact" class="btn btn-secondary">Get Started</a>
            </div>
        </div>
    </div>
</section>

