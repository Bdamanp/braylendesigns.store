<!-- WHY BRAYLEN -->
<section class="section" id="why">
    <div class="container">
        <span class="section-label reveal">Why Braylen Digital</span>
        <h2 class="section-title reveal">Built different, <span class="gradient-text">by design.</span></h2>
        <p class="section-subtitle reveal">No bloated agency overhead. No months-long timelines. Just clean, fast websites that actually bring in customers.</p>
        <div class="grid-3">
            <div class="card reveal reveal-delay-1" >
                <div class="card-icon">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <h3>5-7 Day Turnaround</h3>
                <p>Your site goes live in under a week. Most agencies take 6-8 weeks for the same deliverable.</p>
            </div>
            <div class="card reveal reveal-delay-2" >
                <div class="card-icon">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <h3>No Agency Markups</h3>
                <p>Pro-quality results at a fraction of the cost. You pay for the work, not the overhead.</p>
            </div>
            <div class="card reveal reveal-delay-3" >
                <div class="card-icon">
                    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3>Mobile-First, SEO-Ready</h3>
                <p>Every site is optimized for phones and search engines from day one. Your customers can find you.</p>
            </div>
        </div>
    </div>
</section>

<div class="section-divider"></div>

