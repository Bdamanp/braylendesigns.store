<!-- CONTACT -->
<section class="section" id="contact" style="position:relative;">
    <div class="blob blob-1" style="width:400px;height:400px;top:auto;bottom:-20%;right:10%;"></div>
    <div class="container">
        <div class="contact-grid">
            <div>
                <span class="section-label reveal">Get in Touch</span>
                <h2 class="section-title reveal">Ready to upgrade <span class="gradient-text">your online presence?</span></h2>
                <p class="section-subtitle reveal">Fill out the form and I will get back to you within 24 hours with a free quote and project timeline.</p>
                <form class="reveal" id="contactForm">
                    <div class="form-group">
                        <input type="text" id="name" placeholder=" " required>
                        <label for="name">Your Name</label>
                    </div>
                    <div class="form-group">
                        <input type="text" id="business" placeholder=" ">
                        <label for="business">Business Name</label>
                    </div>
                    <div class="form-group">
                        <input type="email" id="email" placeholder=" " required>
                        <label for="email">Email Address</label>
                    </div>
                    <div class="form-group">
                        <input type="tel" id="phone" placeholder=" ">
                        <label for="phone">Phone Number</label>
                    </div>
                    <div class="form-group">
                        <textarea id="message" placeholder=" " rows="4"></textarea>
                        <label for="message">Tell me about your project</label>
                    </div>
                    <button type="submit" class="btn btn-primary" id="submitBtn" style="width:100%;justify-content:center;">
                        <span class="btn-text">Send Message</span>
                        <svg class="btn-spinner" style="display:none;" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="32"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/><animate attributeName="stroke-dashoffset" values="32;0;32" dur="1.2s" repeatCount="indefinite"/></circle></svg>
                    </button>
                </form>
            </div>
            <div class="contact-info reveal">
                <div style="margin-bottom:16px;">
                    <h3>Let's talk about your project.</h3>
                    <p style="margin-top:12px;">Whether you need a brand new site or a refresh of your current one, I'm here to help you look professional online.</p>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">
                        <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <div>
                        <strong>Email</strong>
                        <p><a href="mailto:contact@braylendesigns.store" style="color:var(--accent);">contact@braylendesigns.store</a></p>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">
                        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </div>
                    <div>
                        <strong>Phone</strong>
                        <p><a href="tel:+13177946555" style="color:var(--accent);">(317) 794-6555</a></p>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">
                        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div>
                        <strong>Location</strong>
                        <p>Plainfield, Indiana</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
